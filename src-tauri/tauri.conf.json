{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenWiki",
  "version": "0.3.5",
  "identifier": "com.openwiki.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "",
        "hiddenTitle": true,
        "url": "/",
        "width": 1200,
        "height": 850,
        "resizable": true,
        "decorations": true,
        "transparent": true,
        "titleBarStyle": "Overlay",
        "visible": false,
        "center": true
      },
      {
        "label": "spotlight",
        "title": "",
        "url": "/spotlight",
        "width": 520,
        "height": 80,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "visible": false,
        "center": true,
        "alwaysOnTop": true,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; img-src 'self' asset: http://asset.localhost; style-src 'self' 'unsafe-inline'",
      "assetProtocol": {
        "enable": true,
        "scope": ["**/*"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "scripts/*": "scripts/",
      "resources/markitdown/**/*": "markitdown/",
      "resources/openwiki_ocr_bin": "openwiki_ocr_bin"
    },
    "macOS": {
      "infoPlist": "./Info.plist",
      "entitlements": "./entitlements.plist",
      "dmg": {
        "background": "resources/dmg_background.tiff",
        "windowSize": { "width": 660, "height": 400 },
        "appPosition": { "x": 180, "y": 170 },
        "applicationFolderPosition": { "x": 480, "y": 170 }
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEJDQTBFQkEyOEFGQUMzREMKUldUY3cvcUtvdXVndkgwVmx1K2Z6S0lmOFpJcEpjcFlBWDNXSkZnWnZLbTc2c1F2K2JrWXZpcE8K",
      "endpoints": [
        "https://github.com/kdsz001/OpenWiki/releases/latest/download/latest.json"
      ]
    }
  }
}
